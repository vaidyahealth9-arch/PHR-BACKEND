# Backend environment template (Part 1)

# Runtime mode
ENVIRONMENT=development

# Internal service communication
# INTERNAL_AUTH_MODE: auto | local | oidc
INTERNAL_AUTH_MODE=local
INTERNAL_SECRET_KEY=replace-with-shared-internal-secret
INTERNAL_ALLOWED_SERVICE_ACCOUNTS=
LIMS_SERVICE_URL=http://lims-backend:8080
LIMS_SERVICE_URL_CLOUD=
PHR_SERVICE_URL=http://phr-backend:8000
PHR_SERVICE_URL_CLOUD=

# Use PostgreSQL in docker-compose
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/phr

# JWT signing key (replace in non-local environments)
SECRET_KEY=replace-with-a-long-random-secret

# Token lifecycle
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# OTP lifecycle
OTP_TTL_SECONDS=300
OTP_RESEND_COOLDOWN_SECONDS=30
OTP_MAX_SENDS_PER_HOUR=5
OTP_MAX_VERIFY_ATTEMPTS=5
OTP_VERIFICATION_LOCK_MINUTES=15

# Optional WhatsApp OTP settings
WHATSAPP_API_URL=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_OTP_TEMPLATE_NAME=otp_verification
WHATSAPP_OTP_TEMPLATE_LANGUAGE=en
